      },
      "targets": [
        {
          "expr": "sum(rate(ml_prediction_value_sum[15s])) / sum(rate(ml_prediction_value_count[15s]))",
          "legendFormat": "Avg Prediction",
          "refId": "A",
          "interval": "5s"
        }
      ]
    },
